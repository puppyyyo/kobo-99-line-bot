# LINE Messaging API 設定
# 取得方式請看 README.md 的 "LINE Bot 申請步驟"
LINE_CHANNEL_TOKEN=your_long_lived_channel_access_token_here
LINE_USER_ID=your_user_id_here

# 排程時間（24h 制，台北時區）
# 預設週三 19:00：Kobo 通常週三發佈當週書單
SCHEDULE_DAY=wed
SCHEDULE_HOUR=19
SCHEDULE_MINUTE=0

# 啟動時是否立刻跑一次（first run 測試用，之後可設 false）
RUN_ON_STARTUP=true
